rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount'])
      );

      match /pets/{petId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /following/{followingId} {
        allow read: if true;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /followers/{followerId} {
        allow read: if true;
        allow create, delete: if request.auth != null && request.auth.uid == followerId;
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'likes', 'likedBy'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == request.resource.data.uid;
        allow delete: if request.auth.uid == resource.data.uid;
      }
    }

    match /chats/{chatId} {
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participantIds);
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participantIds;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    match /swipes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /swiped/{targetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /likes/{targetId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /matches/{matchId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == matchId);
      }
    }

    match /notifications/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /items/{itemId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

  }
}
