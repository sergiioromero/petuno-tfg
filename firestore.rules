rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios - cualquier usuario autenticado puede leer, solo el dueño escribe
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update, delete: if request.auth.uid == userId;

      match /pets/{petId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth.uid == followerId;
      }

      match /following/{followingId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth.uid == userId;
      }
    }

    // Publicaciones - cualquier usuario autenticado puede leer
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth.uid == resource.data.uid;

      // COMENTARIOS - TODOS los usuarios autenticados pueden leer
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == request.resource.data.uid;
        allow delete: if request.auth.uid == resource.data.uid;
      }
    }

    // Notificaciones - solo el destinatario
    match /notifications/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /items/{itemId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Swipes - solo el usuario dueño
    match /swipes/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /swiped/{swipedId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
  }
}
